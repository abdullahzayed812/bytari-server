# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/veterinary_app

# Server Configuration
PORT=80
NODE_ENV=development

# JWT Secret (generate a secure one for production)
JWT_SECRET=your-super-secret-jwt-key-here

# AI Configuration (optional)
OPENAI_API_KEY=your-openai-api-key-here
AI_MODEL=gpt-3.5-turbo

# Email Configuration (optional)
EMAIL_USER=baytariapp@gmail.com
EMAIL_PASS=your-gmail-password-or-app-password
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password

# Cloudflare R2 Storage
R2_ACCOUNT_ID=e9d53627a10f82c5f66da84d8ce39cf6
R2_ACCESS_KEY_ID=83246b15b5d5fd5be5f3f0f5d7f2b135
R2_SECRET_ACCESS_KEY=5b69b85587a44d10d9a7a3abfb297cbbf20ca3b3ac1e766a2f6684a2fff9f437
R2_BUCKET_NAME=bytari-assets
R2_PUBLIC_URL=https://pub-884b1b05d7dc4b9db0bba4df9a6985cb.r2.dev

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Production CORS Origins (comma-separated)
PRODUCTION_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

